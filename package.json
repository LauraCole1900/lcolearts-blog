{
  "name": "lcolearts-blog",
  "version": "1.0.0",
  "description": "My blog",
  "author": "Laura E. Cole",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "dev": "concurrently \"cd server && npm run watch\" \"cd client && npm run dev\"",
