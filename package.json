  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": "24.23.0",
    "npm": "11.6.2"
  }
}
